# Local dev (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://salon:salon@localhost:5432/salon_marketplace

# Production: use Neon or Supabase free tier connection string
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/salon_marketplace?ssl=require

SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,https://beauty-salon-app-hackathon.vercel.app
# Optional override; default allows all *.vercel.app deployments
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Google AI Studio — required for AI chat agent (free tier)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Gemini model for AI chat (change if you hit rate limits or 503 busy errors)
# Examples: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-3-flash-preview, gemini-flash-latest
LLM_MODEL=gemini-2.5-flash
# Auto-fallback when primary model returns 503 UNAVAILABLE
LLM_MODEL_FALLBACK=gemini-2.5-flash-lite

# MCP endpoint used by ADK agents (default: same server)
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# Rate limiting (per client IP, rolling 60s window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_WRITE_PER_MINUTE=40
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AGENT_PER_MINUTE=20
